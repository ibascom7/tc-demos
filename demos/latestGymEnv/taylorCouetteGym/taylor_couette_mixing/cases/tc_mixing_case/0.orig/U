FoamFile
{
    version         2;
    format          binary;
    class           volVectorField;
    object          U;
}

dimensions      [ 0 1 -1 0 0 0 0 ];

internalField   uniform ( 0 0 0 );

boundaryField
{
    "inner_wall"
    {
        type            rotatingWallVelocity;
        origin          ( 0 0 0 );
        axis            ( 0 0 1 );
        omega           52.4;
    }
    "outer_wall"
    {
        type            rotatingWallVelocity;
        origin          ( 0 0 0 );
        axis            ( 0 0 1 );
        omega           0;
    }
    "top"
    {
        type            fixedValue;
        value           uniform ( 0 0 -0.001462 );
    }
    "bottom"
    {
        type            inletOutlet;
        inletValue      uniform ( 0 0 0 );
        value           uniform ( 0 0 0 );
    }
    "front"
    {
        type            wedge;
    }
    "back"
    {
        type            wedge;
    }
}


